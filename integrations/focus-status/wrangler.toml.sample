name = "brighton-focus-status"
main = "cloudflare-worker.js"
compatibility_date = "2026-03-02"
workers_dev = true

# KV binding for latest focus state.
[[kv_namespaces]]
binding = "FOCUS_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

[vars]
FOCUS_ALLOWED_ORIGINS = "https://brightonxx.github.io,http://localhost:1314,http://localhost:1313"
